{
  "manifest_version": 3,
  "name": "Habit Calendar Mobile Sync",
  "version": "1.0.0",
  "description": "Syncs mobile Safari history to the Habit Calendar companion app.",
  "permissions": [
    "history",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:19848/",
    "http://localhost:19848/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Habit Calendar Sync"
  }
}
