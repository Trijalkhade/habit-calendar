{
    "manifest_version": 3,
    "name": "Habit Calendar",
    "version": "1.0.0",
    "description": "Tracks coding habit completions and blacklisted site visits for Habit Calendar app",
    "permissions": ["webNavigation", "storage", "history"],
    "host_permissions": [
        "https://leetcode.com/*",
        "https://takeuforward.in/*",
        "https://takeuforward.org/*"
    ],
    "content_scripts": [
        {
            "matches": ["https://leetcode.com/*"],
            "js": ["content/leetcode.js"],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://takeuforward.in/*", 
                "https://www.takeuforward.in/*",
                "https://takeuforward.org/*",
                "https://www.takeuforward.org/*"
            ],
            "js": ["content/takeuforward.js"],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["content/inject.js"],
            "matches": ["https://leetcode.com/*"]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Habit Calendar Sync"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
